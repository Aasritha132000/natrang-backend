<div style="
  min-height:100vh;
  display:flex;
  align-items:center;
  justify-content:center;
  padding:10px 16px;
 background-image: url('<%= asset_path('dance_bg.jpg') %>');
  position:relative;
  background-size: cover;
  background-position: center;
  background-attachment: fixed;
">
  <div style="background:white; border-radius:16px; border:1px solid #f3f4f6; width:100%; max-width:400px; overflow:hidden; box-shadow:0 8px 40px rgba(0,0,0,0.5);">

    <!-- ORANGE BANNER -->
    <div style="background:#f97316; padding:16px 28px; text-align:center;">
      <div style="font-size:11px; font-weight:600; color:white; letter-spacing:2px; text-transform:uppercase; opacity:0.85; margin-bottom:3px;">Welcome to</div>
      <div style="font-size:24px; font-weight:700; color:white;">💃 NataRang</div>
      <div style="font-size:11px; color:white; opacity:0.75; margin-top:2px;">India's Dance Universe 🇮🇳</div>
    </div>

    <!-- FORM -->
    <div style="padding:16px 28px 20px;">
      <p style="font-size:14px; font-weight:600; color:#111827; margin:0 0 12px;">Create your account</p>

      <!-- ERRORS -->
      <% if @user.errors.any? %>
        <div style="background:#fef2f2; border:1px solid #fecaca; border-radius:8px; padding:10px 14px; margin-bottom:12px;">
          <% @user.errors.full_messages.each do |msg| %>
            <p style="color:#ef4444; font-size:12px; margin:2px 0;">❌ <%= msg %></p>
          <% end %>
        </div>
      <% end %>

      <%= form_with model: @user, url: users_path, local: true, html: { novalidate: true } do |f| %>

        <!-- Full Name -->
        <div style="margin-bottom:10px;">
          <%= f.label :name, style:"display:block; font-size:11px; font-weight:600; color:#6b7280; margin-bottom:4px; text-transform:uppercase; letter-spacing:0.5px;" do %>
            Full Name
          <% end %>
          <%= f.text_field :name,
              id: "name_field",
              placeholder: "Enter your full name",
              autocomplete: "off",
              oninput: "checkName(this.value)",
              style: "width:100%; box-sizing:border-box; padding:8px 12px; border:1px solid #e5e7eb; border-radius:8px; font-size:13px; outline:none; background:#f9fafb;",
              onfocus: "this.style.borderColor='#f97316'; this.style.background='white'",
              onblur: "this.style.borderColor='#e5e7eb'; this.style.background='#f9fafb'" %>
          <p id="name_hint" style="font-size:11px; margin:3px 0 0;"></p>
        </div>

        <!-- Email -->
        <div style="margin-bottom:10px;">
          <%= f.label :email, style:"display:block; font-size:11px; font-weight:600; color:#6b7280; margin-bottom:4px; text-transform:uppercase; letter-spacing:0.5px;" do %>
            Email Address
          <% end %>
          <%= f.email_field :email,
              id: "email_field",
              placeholder: "Enter your email address",
              autocomplete: "off",
              oninput: "checkEmail(this.value)",
              style: "width:100%; box-sizing:border-box; padding:8px 12px; border:1px solid #e5e7eb; border-radius:8px; font-size:13px; outline:none; background:#f9fafb;",
              onfocus: "this.style.borderColor='#f97316'; this.style.background='white'",
              onblur: "this.style.borderColor='#e5e7eb'; this.style.background='#f9fafb'" %>
          <p id="email_hint" style="font-size:11px; margin:3px 0 0;"></p>
        </div>

        <!-- Password -->
        <div style="margin-bottom:10px;">
          <%= f.label :password, style:"display:block; font-size:11px; font-weight:600; color:#6b7280; margin-bottom:4px; text-transform:uppercase; letter-spacing:0.5px;" do %>
            Password
          <% end %>
          <div style="position:relative;">
            <%= f.password_field :password,
                id: "password_field",
                placeholder: "Min 6 characters",
                autocomplete: "new-password",
                oninput: "checkPassword(this.value)",
                style: "width:100%; box-sizing:border-box; padding:8px 40px 8px 12px; border:1px solid #e5e7eb; border-radius:8px; font-size:13px; outline:none; background:#f9fafb;",
                onfocus: "this.style.borderColor='#f97316'; this.style.background='white'",
                onblur: "this.style.borderColor='#e5e7eb'; this.style.background='#f9fafb'" %>
            <button type="button" onclick="togglePassword('password_field', 'eye1')"
              style="position:absolute; right:10px; top:50%; transform:translateY(-50%); background:none; border:none; cursor:pointer; padding:0; color:#9ca3af; display:flex;">
              <svg id="eye1" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                <circle cx="12" cy="12" r="3"></circle>
              </svg>
            </button>
          </div>
          <p id="pwd_hint" style="font-size:11px; color:#9ca3af; margin:3px 0 0;">Must be at least 6 characters</p>
        </div>

        <!-- Confirm Password -->
        <div style="margin-bottom:10px;">
          <%= f.label :password_confirmation, style:"display:block; font-size:11px; font-weight:600; color:#6b7280; margin-bottom:4px; text-transform:uppercase; letter-spacing:0.5px;" do %>
            Confirm Password
          <% end %>
          <div style="position:relative;">
            <%= f.password_field :password_confirmation,
                id: "confirm_password_field",
                placeholder: "Re-enter your password",
                autocomplete: "new-password",
                oninput: "checkConfirmPassword(this.value)",
                style: "width:100%; box-sizing:border-box; padding:8px 40px 8px 12px; border:1px solid #e5e7eb; border-radius:8px; font-size:13px; outline:none; background:#f9fafb;",
                onfocus: "this.style.borderColor='#f97316'; this.style.background='white'",
                onblur: "this.style.borderColor='#e5e7eb'; this.style.background='#f9fafb'" %>
            <button type="button" onclick="togglePassword('confirm_password_field', 'eye2')"
              style="position:absolute; right:10px; top:50%; transform:translateY(-50%); background:none; border:none; cursor:pointer; padding:0; color:#9ca3af; display:flex;">
              <svg id="eye2" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                <circle cx="12" cy="12" r="3"></circle>
              </svg>
            </button>
          </div>
          <p id="confirm_hint" style="font-size:11px; margin:3px 0 0;"></p>
        </div>

        <!-- Terms & Conditions -->
        <div style="margin-bottom:14px; display:flex; align-items:flex-start; gap:8px;">
          <input type="checkbox" id="terms" required
            style="margin-top:2px; accent-color:#f97316; width:13px; height:13px; cursor:pointer; flex-shrink:0;" />
          <label for="terms" style="font-size:11px; color:#6b7280; cursor:pointer; line-height:1.6;">
            I agree to the
            <a href="#" style="color:#f97316; font-weight:600; text-decoration:none;">Terms of Service</a>
            and
            <a href="#" style="color:#f97316; font-weight:600; text-decoration:none;">Privacy Policy</a>
          </label>
        </div>

        <!-- Submit -->
        <%= f.submit "Create Account",
            style: "width:100%; background:#f97316; color:white; border:none; border-radius:8px; padding:10px; font-size:14px; font-weight:600; cursor:pointer;",
            onmouseover: "this.style.background='#dc2626'",
            onmouseout: "this.style.background='#f97316'" %>

      <% end %>

      <!-- Divider -->
      <div style="display:flex; align-items:center; gap:12px; margin:12px 0;">
        <div style="flex:1; height:1px; background:#f3f4f6;"></div>
        <span style="font-size:11px; color:#d1d5db;">or</span>
        <div style="flex:1; height:1px; background:#f3f4f6;"></div>
      </div>

      <p style="text-align:center; font-size:13px; color:#9ca3af; margin:0;">
        Already have an account?
        <%= link_to "Login here", login_path, style:"color:#f97316; font-weight:600; text-decoration:none;" %>
      </p>

    </div>
  </div>
</div>

<script>
function togglePassword(inputId, iconId) {
  const input = document.getElementById(inputId);
  const icon = document.getElementById(iconId);
  if (input.type === 'password') {
    input.type = 'text';
    icon.innerHTML = `<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"></path><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"></path><line x1="1" y1="1" x2="23" y2="23"></line>`;
    icon.style.color = '#f97316';
  } else {
    input.type = 'password';
    icon.innerHTML = `<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle>`;
    icon.style.color = '#9ca3af';
  }
}

function checkName(value) {
  const hint = document.getElementById('name_hint');
  const field = document.getElementById('name_field');
  if (value.length === 0) {
    hint.textContent = '';
    field.style.borderColor = '#e5e7eb';
  } else if (value.length < 2) {
    hint.textContent = '❌ Name is too short';
    hint.style.color = '#ef4444';
    field.style.borderColor = '#ef4444';
  } else {
    hint.textContent = '✅ Looks good!';
    hint.style.color = '#22c55e';
    field.style.borderColor = '#22c55e';
  }
}

function checkEmail(value) {
  const hint = document.getElementById('email_hint');
  const field = document.getElementById('email_field');
  const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
  if (value.length === 0) {
    hint.textContent = '';
    field.style.borderColor = '#e5e7eb';
  } else if (!emailRegex.test(value)) {
    hint.textContent = '❌ Please enter a valid email address';
    hint.style.color = '#ef4444';
    field.style.borderColor = '#ef4444';
  } else {
    hint.textContent = '✅ Email looks good!';
    hint.style.color = '#22c55e';
    field.style.borderColor = '#22c55e';
  }
}

function checkPassword(value) {
  const hint = document.getElementById('pwd_hint');
  const field = document.getElementById('password_field');
  if (value.length === 0) {
    hint.textContent = 'Must be at least 6 characters';
    hint.style.color = '#9ca3af';
    field.style.borderColor = '#e5e7eb';
  } else if (value.length < 6) {
    hint.textContent = '❌ Too short! Need ' + (6 - value.length) + ' more characters';
    hint.style.color = '#ef4444';
    field.style.borderColor = '#ef4444';
  } else {
    hint.textContent = '✅ Password looks good!';
    hint.style.color = '#22c55e';
    field.style.borderColor = '#22c55e';
  }
}

function checkConfirmPassword(value) {
  const hint = document.getElementById('confirm_hint');
  const field = document.getElementById('confirm_password_field');
  const original = document.getElementById('password_field').value;
  if (value.length === 0) {
    hint.textContent = '';
    field.style.borderColor = '#e5e7eb';
  } else if (value !== original) {
    hint.textContent = '❌ Passwords do not match!';
    hint.style.color = '#ef4444';
    field.style.borderColor = '#ef4444';
  } else {
    hint.textContent = '✅ Passwords match!';
    hint.style.color = '#22c55e';
    field.style.borderColor = '#22c55e';
  }
}
</script>